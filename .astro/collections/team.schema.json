{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "photo": {
      "type": "string"
    },
    "photoAlt": {
      "type": "string"
    },
    "order": {
      "default": 99,
      "type": "number"
    },
    "founder": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "role"
  ]
}