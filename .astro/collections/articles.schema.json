{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "imunitet",
        "hranene",
        "razvitie",
        "psihologia",
        "imunizacii",
        "speshni",
        "obshto"
      ]
    },
    "cover": {
      "type": "string"
    },
    "coverAlt": {
      "type": "string"
    },
    "author": {
      "default": "д-р Мерилин Иванова",
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "readingTime": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "excerpt",
    "date",
    "category"
  ]
}