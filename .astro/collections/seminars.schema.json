{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "location": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "cover": {
      "type": "string"
    },
    "coverAlt": {
      "type": "string"
    },
    "registrationPhone": {
      "type": "string"
    },
    "registrationLink": {
      "type": "string",
      "format": "uri"
    },
    "speakers": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "location",
    "description"
  ]
}