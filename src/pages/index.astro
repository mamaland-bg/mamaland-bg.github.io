---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SeminarCard from '../components/SeminarCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

const allSeminars = await getCollection('seminars', ({ data }) => !data.draft);
const now = new Date();
const upcomingSeminar = allSeminars
  .filter(s => new Date(s.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf())[0];
---

<Base>

  <section class="hero">
    <div class="hero-shapes" aria-hidden="true">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>
    <div class="container-narrow hero-content">
      <div class="eyebrow">МАМИНАТА ЗЕМЯ</div>
      <h1 class="hero-title">
        <span class="script hero-script">Здраве и спокойствие</span>
        <span class="hero-sub">за всяко малко сърце</span>
      </h1>
      <p class="hero-lede">
        Прочити, статии и семинари за детското здраве и развитие — от педиатър и психолог,
        които вярват, че информираните родители са най-доброто лекарство.
      </p>
      <div class="hero-actions">
        <a href="/articles" class="btn btn-primary">Прочети последните статии →</a>
        <a href="/about" class="btn btn-ghost">За нас</a>
      </div>
      <div class="divider-sparkle"></div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <header class="section-header">
        <div class="eyebrow">ПОСЛЕДНИ СТАТИИ</div>
        <h2 class="script section-script">от блога</h2>
      </header>

      {latestArticles.length > 0 ? (
        <div class="article-grid">
          {latestArticles.map(article => (
            <ArticleCard
              title={article.data.title}
              excerpt={article.data.excerpt}
              slug={article.id}
              category={article.data.category}
              date={article.data.date}
              cover={article.data.cover}
              coverAlt={article.data.coverAlt}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">Скоро ще намерите тук първите статии — следете ни.</p>
      )}

      <div class="section-cta">
        <a href="/articles" class="btn btn-ghost">Виж всички статии →</a>
      </div>
    </div>
  </section>

  {upcomingSeminar && (
    <section class="section section-cream">
      <div class="container">
        <header class="section-header">
          <div class="eyebrow">ПРЕДСТОИ</div>
          <h2 class="script section-script">семинар</h2>
        </header>

        <SeminarCard
          title={upcomingSeminar.data.title}
          date={upcomingSeminar.data.date}
          endDate={upcomingSeminar.data.endDate}
          location={upcomingSeminar.data.location}
          description={upcomingSeminar.data.description}
          slug={upcomingSeminar.id}
          cover={upcomingSeminar.data.cover}
          coverAlt={upcomingSeminar.data.coverAlt}
        />

        <div class="section-cta">
          <a href="/seminars" class="btn btn-ghost">Всички семинари →</a>
        </div>
      </div>
    </section>
  )}

  <section class="section section-sage">
    <div class="container">
      <div class="about-preview">
        <div class="about-text">
          <div class="eyebrow">ЗАПОЗНАЙТЕ СЕ</div>
          <h2 class="script">с нас</h2>
          <p class="about-lede">
            Mamaland е създаден от <em>д-р Мерилин Иванова</em> — педиатър и клиничен
            психолог с дългогодишен опит в детското здравеопазване. След години в
            Спешна педиатрия на Пирогов и работа по време на пандемията, тя
            преминава към семейна медицина в Nuviva.
          </p>
          <p class="about-lede">
            Тук споделяме знания, събрани от години практика с деца и техните семейства —
            научно базирани, но изговорени с топлота и уважение към всеки родител.
          </p>
          <a href="/about" class="btn btn-secondary">Прочетете повече →</a>
        </div>
        <div class="about-visual" aria-hidden="true">
          <div class="about-blob"></div>
          <div class="about-blob-2"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-periwinkle">
    <div class="container-narrow">
      <div class="newsletter">
        <h2 class="script newsletter-script">Бъдете в крак</h2>
        <p class="newsletter-lede">
          Получавайте нови статии и информация за предстоящи семинари директно в пощата си.
        </p>
        <form class="newsletter-form" action="#" method="POST" data-netlify="true" name="newsletter">
          <input type="email" name="email" placeholder="вашият имейл" required aria-label="Имейл адрес" />
          <button type="submit" class="btn btn-secondary">Запиши се</button>
        </form>
        <p class="newsletter-fineprint">Без спам. Можете да се отпишете по всяко време.</p>
      </div>
    </div>
  </section>

</Base>

<style>
  .hero {
    position: relative;
    background: var(--color-cream);
    padding: var(--space-2xl) 0;
    overflow: hidden;
  }

  .hero-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .shape {
    position: absolute;
    border-radius: var(--radius-blob);
    opacity: 0.5;
  }

  .shape-1 {
    width: 280px; height: 280px;
    background: var(--color-sage);
    top: -60px; left: -80px;
  }

  .shape-2 {
    width: 200px; height: 200px;
    background: var(--color-peach);
    bottom: -40px; right: -60px;
    border-radius: 45% 55% 60% 40% / 55% 45% 55% 45%;
    opacity: 0.4;
  }

  .shape-3 {
    width: 140px; height: 140px;
    background: var(--color-periwinkle-light);
    top: 30%; right: 8%;
    border-radius: 50% 50% 45% 55% / 60% 50% 50% 40%;
    opacity: 0.3;
  }

  .hero-content {
    position: relative;
    text-align: center;
  }

  .hero-title {
    margin: 1rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero-script {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1;
  }

  .hero-sub {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-style: italic;
    color: var(--color-ink-soft);
    font-weight: 400;
  }

  .hero-lede {
    font-size: 1.05rem;
    color: var(--color-ink-soft);
    max-width: 560px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-script {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-top: 0.25rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .empty-state {
    text-align: center;
    color: var(--color-ink-muted);
    font-style: italic;
    padding: 3rem 0;
  }

  .section-cta {
    text-align: center;
  }

  .about-preview {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-text h2.script {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 1.5rem;
  }

  .about-lede {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .about-lede em {
    font-style: italic;
    color: var(--color-periwinkle-dark);
  }

  .about-visual {
    position: relative;
    aspect-ratio: 1;
  }

  .about-blob {
    position: absolute;
    inset: 0;
    background: var(--color-sage);
    border-radius: var(--radius-blob);
    opacity: 0.6;
  }

  .about-blob-2 {
    position: absolute;
    width: 70%;
    height: 70%;
    top: 15%;
    left: 20%;
    background: var(--color-peach);
    border-radius: 55% 45% 50% 50% / 45% 55% 45% 55%;
    opacity: 0.7;
  }

  .newsletter {
    text-align: center;
  }

  .newsletter-script {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--color-cream);
    margin-bottom: 0.5rem;
  }

  .newsletter-lede {
    color: var(--color-cream);
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    max-width: 440px;
    margin: 0 auto;
  }

  .newsletter-form input {
    flex: 1;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    border: none;
    background: var(--color-cream);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  .newsletter-form input::placeholder {
    color: var(--color-brown-warm);
  }

  .newsletter-fineprint {
    font-size: 0.8rem;
    color: var(--color-cream);
    opacity: 0.7;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .about-preview {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-visual {
      max-width: 280px;
      margin: 0 auto;
    }

    .newsletter-form {
      flex-direction: column;
    }
  }
</style>
