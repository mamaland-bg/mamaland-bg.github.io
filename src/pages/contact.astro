---
import Base from '../layouts/Base.astro';
---

<Base title="Контакт — Mamaland" description="Свържете се с екипа на Mamaland.">

  <section class="page-hero">
    <div class="container-narrow">
      <div class="eyebrow">СВЪРЗЕТЕ СЕ</div>
      <h1 class="script">с нас</h1>
      <p class="page-lede">
        Имате въпрос, идея за тема или предложение за сътрудничество?
        Ще се радваме да чуем от вас.
      </p>
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-info">
          <h2>Връзка</h2>

          <div class="contact-item">
            <div class="contact-label">Email</div>
            <a href="mailto:hello@mamaland.bg" class="contact-value">hello@mamaland.bg</a>
          </div>

          <div class="contact-item">
            <div class="contact-label">Instagram</div>
            <a href="https://www.instagram.com/mamaland.sofia/" target="_blank" rel="noopener" class="contact-value">@mamaland.sofia</a>
          </div>

          <div class="contact-item">
            <div class="contact-label">Запазване на час</div>
            <p class="contact-value">
              Д-р Мерилин Иванова приема пациенти в<br/>
              <strong>Медицински център Nuviva</strong><br/>
              Бул. Черни връх 155, сграда Nexa<br/>
              София
            </p>
            <a href="tel:+35989999156" class="btn btn-primary" style="margin-top: 0.75rem;">
              📞 +359 89 999 9156
            </a>
          </div>

          <div class="contact-note">
            <p>
              <em>Mamaland не е заместител на медицинска консултация.
              За въпроси, изискващи преглед, моля запазете час.</em>
            </p>
          </div>
        </div>

        <div class="contact-form-wrap">
          <h2>Напишете ни</h2>
          <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            <label>
              <span>Име</span>
              <input type="text" name="name" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" required />
            </label>
            <label>
              <span>Тема</span>
              <input type="text" name="subject" />
            </label>
            <label>
              <span>Съобщение</span>
              <textarea name="message" rows="6" required></textarea>
            </label>
            <button type="submit" class="btn btn-primary">Изпрати →</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    background: var(--color-cream);
    padding: var(--space-xl) 0 var(--space-lg);
    text-align: center;
  }

  .page-hero .script {
    font-size: clamp(3rem, 7vw, 5rem);
    margin: 0.5rem 0 1rem;
  }

  .page-lede {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
  }

  .contact-info h2,
  .contact-form-wrap h2 {
    font-family: var(--font-script);
    font-size: 2.5rem;
    color: var(--color-periwinkle-dark);
    margin-bottom: 2rem;
  }

  .contact-item {
    margin-bottom: 2rem;
  }

  .contact-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brown-warm);
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .contact-value {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-ink);
    line-height: 1.6;
  }

  .contact-note {
    background: var(--color-sage-bg);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    margin-top: 2rem;
    font-size: 0.9rem;
    color: var(--color-sage-deep);
  }

  .contact-note em {
    font-style: italic;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact-form span {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brown-warm);
    font-weight: 600;
  }

  .contact-form input,
  .contact-form textarea {
    padding: 0.85rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(0,0,0,0.1);
    background: var(--color-cream);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    transition: border-color 0.2s ease;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-periwinkle);
  }

  .contact-form button {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
