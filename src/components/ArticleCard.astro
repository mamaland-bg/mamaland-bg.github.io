---
import { Image } from 'astro:assets';
import { CATEGORIES } from '../lib/categories';

export interface Props {
  title: string;
  excerpt: string;
  slug: string;
  category: string;
  date: Date;
  cover?: any;
  coverAlt?: string;
}

const { title, excerpt, slug, category, date, cover, coverAlt } = Astro.props;
const cat = CATEGORIES[category] || CATEGORIES.obshto;
const formattedDate = new Intl.DateTimeFormat('bg-BG', {
  day: 'numeric', month: 'long', year: 'numeric'
}).format(new Date(date));
---

<article class={`article-card card-${cat.tone}`}>
  <a href={`/articles/${slug}`} class="card-link">
    {cover ? (
      <div class="card-image-wrap">
        <Image src={cover} alt={coverAlt || title} class="card-image" widths={[400, 600, 800]} sizes="(max-width: 768px) 100vw, 33vw" />
      </div>
    ) : (
      <div class={`card-image-wrap card-image-placeholder bg-${cat.tone}`}>
        <span class="placeholder-mark">✦</span>
      </div>
    )}
    <div class="card-body">
      <div class={`card-eyebrow eyebrow-${cat.tone}`}>{cat.label}</div>
      <h3 class="card-title">{title}</h3>
      <p class="card-excerpt">{excerpt}</p>
      <div class="card-meta">
        <time datetime={new Date(date).toISOString()}>{formattedDate}</time>
        <span class="card-arrow">→</span>
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s ease;
    background: #fff;
  }

  .article-card:hover {
    transform: translateY(-4px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-cream-deep);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .article-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-mark {
    font-size: 3rem;
    color: var(--color-brown-warm);
    opacity: 0.4;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .eyebrow-sage { color: var(--color-sage-dark); }
  .eyebrow-peach { color: var(--color-peach-dark); }
  .eyebrow-periwinkle { color: var(--color-periwinkle-dark); }
  .eyebrow-pink { color: #B85B6E; }
  .eyebrow-brown { color: var(--color-brown); }

  .bg-sage { background: var(--color-sage); }
  .bg-peach { background: var(--color-peach); }
  .bg-periwinkle { background: var(--color-periwinkle-light); }
  .bg-pink { background: var(--color-pink); }
  .bg-brown { background: var(--color-cream-deep); }

  .card-sage { background: var(--color-sage-bg); }
  .card-peach { background: var(--color-peach-bg); }
  .card-periwinkle { background: var(--color-periwinkle-bg); }
  .card-pink { background: var(--color-pink-bg); }
  .card-brown { background: var(--color-cream-deep); }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
    margin-bottom: 0.5rem;
    line-height: 1.25;
  }

  .card-excerpt {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin-bottom: 1rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    padding-top: 0.5rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .card-arrow {
    font-size: 1.1rem;
    color: var(--color-periwinkle-dark);
    transition: transform 0.2s ease;
  }

  .article-card:hover .card-arrow {
    transform: translateX(4px);
  }
</style>
